<Window x:Class="Calculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calculator" Height="500" Width="320"
        Background="Black">

    <Grid Margin="10">

        <Grid.Resources>
            <Style x:Key="NumberButton" TargetType="Button">
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="Margin" Value="5"/>
                <Setter Property="Background" Value="#333333"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <Style x:Key="OperatorButton" TargetType="Button">
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="Margin" Value="5"/>
                <Setter Property="Background" Value="#FF9500"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <Style x:Key="TopButton" TargetType="Button">
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="Margin" Value="5"/>
                <Setter Property="Background" Value="#A5A5A5"/>
                <Setter Property="Foreground" Value="Black"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="2*" />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <TextBox Grid.Row="0" Grid.ColumnSpan="5"
                 Name="Display"
                 FontSize="40"
                 Text="0"
                 Background="Black"
                 Foreground="White"
                 BorderThickness="0"
                 HorizontalContentAlignment="Right"
                 VerticalContentAlignment="Bottom"/>

        <Button Style="{StaticResource NumberButton}" Grid.Row="1" Grid.Column="0" Content="1" Click="Number_Click"/>
        <Button Style="{StaticResource NumberButton}" Grid.Row="1" Grid.Column="1" Content="2" Click="Number_Click"/>
        <Button Style="{StaticResource NumberButton}" Grid.Row="1" Grid.Column="2" Content="3" Click="Number_Click"/>
        <Button Style="{StaticResource OperatorButton}" Grid.Row="1" Grid.Column="3" Content="+" Click="Operator_Click"/>

        <Button Style="{StaticResource NumberButton}" Grid.Row="2" Grid.Column="0" Content="4" Click="Number_Click"/>
        <Button Style="{StaticResource NumberButton}" Grid.Row="2" Grid.Column="1" Content="5" Click="Number_Click"/>
        <Button Style="{StaticResource NumberButton}" Grid.Row="2" Grid.Column="2" Content="6" Click="Number_Click"/>
        <Button Style="{StaticResource OperatorButton}" Grid.Row="2" Grid.Column="3" Content="-" Click="Operator_Click"/>

        <Button Style="{StaticResource NumberButton}" Grid.Row="3" Grid.Column="0" Content="7" Click="Number_Click"/>
        <Button Style="{StaticResource NumberButton}" Grid.Row="3" Grid.Column="1" Content="8" Click="Number_Click"/>
        <Button Style="{StaticResource NumberButton}" Grid.Row="3" Grid.Column="2" Content="9" Click="Number_Click"/>
        <Button Style="{StaticResource OperatorButton}" Grid.Row="3" Grid.Column="3" Content="*" Click="Operator_Click"/>

        <Button Style="{StaticResource OperatorButton}" Grid.Row="4" Grid.Column="0" Content="^" Click="Operator_Click"/>
        <Button Style="{StaticResource NumberButton}" Grid.Row="4" Grid.Column="1" Content="0" Click="Number_Click"/>
        <Button Style="{StaticResource OperatorButton}" Grid.Row="4" Grid.Column="2" Content="%" Click="Operator_Click"/>
        <Button Style="{StaticResource OperatorButton}" Grid.Row="4" Grid.Column="3" Content="/" Click="Operator_Click"/>

        <Button Style="{StaticResource OperatorButton}" Grid.Row="5" Grid.Column="0" Content="Sin" Click="Operator_Click"/>
        <Button Style="{StaticResource OperatorButton}" Grid.Row="5" Grid.Column="1" Content="Cos" Click="Operator_Click"/>
        <Button Style="{StaticResource OperatorButton}" Grid.Row="5" Grid.Column="2" Content="Sqrt" Click="Operator_Click"/>
        <Button Style="{StaticResource OperatorButton}" Grid.Row="5" Grid.Column="3" Content="," Click="Comma_Click"/>

        <Button Style="{StaticResource TopButton}"
                Grid.Row="1" Grid.Column="4"
                Content="C"
                Grid.RowSpan="2"
                Click="Clear_Click"/>

        <Button Style="{StaticResource OperatorButton}"
                Grid.Row="3" Grid.Column="4"
                Content="="
                Grid.RowSpan="3"
                Click="Equals_Click"/>
    </Grid>
</Window>
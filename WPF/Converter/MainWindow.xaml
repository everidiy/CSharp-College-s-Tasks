<Window x:Class="ConverterApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Конвертер валют" Height="450" Width="400"
        Background="#FF2C3E50" 
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Grid Margin="20">
        <StackPanel>

            <!-- Сумма -->
            <TextBlock Text="Sum" 
                       Foreground="White" 
                       FontSize="14" 
                       FontWeight="SemiBold" />
            <TextBox x:Name="txtAmount" 
                     Margin="0,5,0,15" 
                     Background="#FF34495E" 
                     Foreground="White" 
                     BorderBrush="#FF1ABC9C" 
                     BorderThickness="2"
                     Padding="5"/>

            <!-- Из валюты -->
            <TextBlock Text="Из:" 
                       Foreground="White" 
                       FontSize="14" 
                       FontWeight="SemiBold"/>
            <ComboBox x:Name="comboFrom" 
                      Margin="0,5,0,15" 
                      Background="#FF34495E" 
                      Foreground="Black" 
                      BorderBrush="#FF1ABC9C" 
                      BorderThickness="2"/>

            <!-- В валюту -->
            <TextBlock Text="В:" 
                       Foreground="White" 
                       FontSize="14" 
                       FontWeight="SemiBold"/>
            <ComboBox x:Name="comboTo" 
                      Margin="0,5,0,20" 
                      Background="#FF34495E" 
                      Foreground="Black" 
                      BorderBrush="#FF1ABC9C" 
                      BorderThickness="2"/>

            <!-- Кнопка -->
            <Button Content="Convert" 
                    Click="Convert_Click" 
                    Height="40" 
                    FontWeight="Bold" 
                    Foreground="White" 
                    BorderThickness="0" 
                    Margin="0,0,0,20">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF1ABC9C" Offset="0"/>
                        <GradientStop Color="#FF16A085" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
            </Button>

            <!-- Результат -->
            <TextBlock Text="Result:" 
                       Foreground="White" 
                       FontSize="14" 
                       FontWeight="SemiBold" />
            <Border Background="#FF34495E" 
                    CornerRadius="8" 
                    BorderBrush="#FF1ABC9C" 
                    BorderThickness="2"
                    Margin="0,5,0,25"
                    Padding="10">
            <TextBlock x:Name="txtResult" 
               FontSize="20"
               Foreground="White"
               TextWrapping="Wrap"/>
            </Border>

        </StackPanel>
    </Grid>
</Window>